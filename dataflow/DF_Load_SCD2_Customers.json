{
	"name": "DF_Load_SCD2_Customers",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "dim_customer",
						"type": "DatasetReference"
					},
					"name": "srcSilverCustomers"
				},
				{
					"dataset": {
						"referenceName": "AzureSqlTable1",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "AzureSqlTable1",
						"type": "DatasetReference"
					},
					"name": "SinkUpdatedRows"
				},
				{
					"dataset": {
						"referenceName": "AzureSqlTable1",
						"type": "DatasetReference"
					},
					"name": "sinkInsertRows"
				}
			],
			"transformations": [
				{
					"name": "selectRenameColumns"
				},
				{
					"name": "derivedAddHash"
				},
				{
					"name": "lookup"
				},
				{
					"name": "split"
				},
				{
					"name": "alterRow"
				},
				{
					"name": "union"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          CustomerName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Country as string,",
				"          CountryName as string,",
				"          Alpha3Code as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'parquet',",
				"     fileSystem: 'silver',",
				"     folderPath: 'Customers') ~> srcSilverCustomers",
				"source(output(",
				"          CustomerKey as integer,",
				"          CustomerID as integer,",
				"          CustomerName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Country as string,",
				"          CountryName as string,",
				"          Alpha3Code as string,",
				"          ValidFrom as timestamp,",
				"          ValidTo as timestamp,",
				"          IsCurrent as boolean,",
				"          InsertedDateUTC as timestamp,",
				"          RowHash_TG as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"srcSilverCustomers select(mapColumn(",
				"          each(match(1==1),",
				"               concat('SRC_',$$) = $$)",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"selectRenameColumns derive(SRC_Hash = crc32(concat(toString(SRC_CustomerID),SRC_CustomerName,SRC_Email,SRC_Phone,SRC_City,SRC_Country))) ~> derivedAddHash",
				"derivedAddHash, select1 lookup(SRC_CustomerID == CustomerID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup",
				"lookup split(isNull(CustomerID),",
				"     SRC_CustomerID == CustomerID && SRC_Hash != TGT_Hash,",
				"     disjoint: false) ~> split@(InsertRows, UpdateExistingRows)",
				"split@UpdateExistingRows alterRow(updateIf(1==1)) ~> alterRow",
				"split@InsertRows, split@UpdateExistingRows union(byName: true)~> union",
				"source1 derive(TGT_Hash = crc32(concat(toString(CustomerID),CustomerName,Email,Phone,City,Country))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          CustomerID,",
				"          TGT_Hash",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"alterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerKey as integer,",
				"          CustomerID as integer,",
				"          CustomerName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Country as string,",
				"          CountryName as string,",
				"          Alpha3Code as string,",
				"          ValidFrom as timestamp,",
				"          ValidTo as timestamp,",
				"          IsCurrent as boolean,",
				"          InsertedDateUTC as timestamp,",
				"          RowHash_TG as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['CustomerID','HASHCOLUMN'],",
				"     skipKeyWrites:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'allErrors',",
				"     transactionCommit: 'single',",
				"     reportSuccessOnError: true,",
				"     mapColumn(",
				"          CustomerID = SRC_CustomerID,",
				"          CustomerName = SRC_CustomerName,",
				"          Email = SRC_Email,",
				"          Phone = SRC_Phone,",
				"          City = SRC_City,",
				"          RowHash_TG = TGT_Hash,",
				"          RowHash_TG = SRC_Hash",
				"     ),",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo') ~> SinkUpdatedRows",
				"union sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerKey as integer,",
				"          CustomerID as integer,",
				"          CustomerName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Country as string,",
				"          CountryName as string,",
				"          Alpha3Code as string,",
				"          ValidFrom as timestamp,",
				"          ValidTo as timestamp,",
				"          IsCurrent as boolean,",
				"          InsertedDateUTC as timestamp,",
				"          RowHash_TG as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     recreate:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          CustomerID = SRC_CustomerID,",
				"          CustomerName = SRC_CustomerName,",
				"          Email = SRC_Email,",
				"          Phone = SRC_Phone,",
				"          City = SRC_City,",
				"          Country = SRC_Country,",
				"          RowHash_TG = SRC_Hash",
				"     ),",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo') ~> sinkInsertRows"
			]
		}
	}
}