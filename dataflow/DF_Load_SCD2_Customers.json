{
	"name": "DF_Load_SCD2_Customers",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "incomingdata",
						"type": "DatasetReference"
					},
					"name": "srcSilverCustomers"
				},
				{
					"dataset": {
						"referenceName": "AzureSqlTable1",
						"type": "DatasetReference"
					},
					"name": "source1"
				},
				{
					"dataset": {
						"referenceName": "AzureSqlTable1",
						"type": "DatasetReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "AzureSqlTable1",
						"type": "DatasetReference"
					},
					"name": "SinkUpdatedRows"
				},
				{
					"name": "sink1"
				},
				{
					"name": "sink2"
				}
			],
			"transformations": [
				{
					"name": "selectRenameColumns"
				},
				{
					"name": "derivedAddHash"
				},
				{
					"name": "lookup"
				},
				{
					"name": "split"
				},
				{
					"name": "alterRow"
				},
				{
					"name": "derivedColumn1"
				},
				{
					"name": "select1"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "derivedColumn4"
				},
				{
					"name": "select2"
				},
				{
					"name": "exists1"
				},
				{
					"name": "derivedColumn5"
				},
				{
					"name": "alterRow1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CustomerID as integer,",
				"          CustomerName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Country as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     fileSystem: 'silver',",
				"     folderPath: 'Customers') ~> srcSilverCustomers",
				"source(output(",
				"          CustomerKey as integer,",
				"          CustomerID as integer,",
				"          CustomerName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Alpha3Code as string,",
				"          ValidFrom as timestamp,",
				"          ValidTo as timestamp,",
				"          IsCurrent as boolean,",
				"          InsertedDateUTC as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source(output(",
				"          CustomerKey as integer,",
				"          CustomerID as integer,",
				"          CustomerName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Alpha3Code as string,",
				"          ValidFrom as timestamp,",
				"          ValidTo as timestamp,",
				"          IsCurrent as boolean,",
				"          InsertedDateUTC as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source2",
				"srcSilverCustomers select(mapColumn(",
				"          each(match(1==1),",
				"               concat('SRC_',$$) = $$)",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> selectRenameColumns",
				"selectRenameColumns derive(SRC_Hash = crc32(concat(toString(SRC_CustomerID),SRC_CustomerName,SRC_Email))) ~> derivedAddHash",
				"derivedAddHash, select1 lookup(SRC_CustomerID == TGT_CustomerID,",
				"     multiple: false,",
				"     pickup: 'any',",
				"     broadcast: 'auto')~> lookup",
				"lookup split(isNull(TGT_CustomerID),",
				"     !isNull(TGT_CustomerID) && SRC_Hash != TGT_Hash,",
				"     disjoint: false) ~> split@(InsertRows, UpdateExistingRows)",
				"derivedColumn4 alterRow(updateIf(1==1)) ~> alterRow",
				"source1 derive(TGT_Hash = crc32(concat(toString(CustomerID),(CustomerName),(Email)))) ~> derivedColumn1",
				"derivedColumn1 select(mapColumn(",
				"          CustomerKey,",
				"          TGT_CustomerID = CustomerID,",
				"          TGT_Hash",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"split@InsertRows derive(IsCurrent = true(),",
				"          ValidFrom = currentUTC(),",
				"          ValidTo = toTimestamp('9999-12-31 23:59:59.999', 'yyyy-MM-dd HH:mm:ss.SSS')) ~> derivedColumn3",
				"split@UpdateExistingRows derive(IsCurrent = true(),",
				"          ValidTo = toTimestamp('9999-12-31 23:59:59.999', 'yyyy-MM-dd HH:mm:ss.SSS')) ~> derivedColumn4",
				"derivedColumn3 select(mapColumn(",
				"          SRC_CustomerID,",
				"          SRC_CustomerName,",
				"          SRC_Email,",
				"          SRC_Phone,",
				"          SRC_City,",
				"          SRC_Country,",
				"          IsCurrent,",
				"          ValidFrom,",
				"          ValidTo",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select2",
				"source2, derivedColumn4 exists(CustomerID == SRC_CustomerID,",
				"     negate:false,",
				"     broadcast: 'auto')~> exists1",
				"exists1 derive(IsCurrent = false(),",
				"          ValideTo = currentUTC()) ~> derivedColumn5",
				"derivedColumn5 alterRow(updateIf(1 == 1)) ~> alterRow1",
				"alterRow sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          CustomerKey as integer,",
				"          CustomerID as integer,",
				"          CustomerName as string,",
				"          Email as string,",
				"          Phone as string,",
				"          City as string,",
				"          Country as string,",
				"          CountryName as string,",
				"          Alpha3Code as string,",
				"          ValidFrom as timestamp,",
				"          ValidTo as timestamp,",
				"          IsCurrent as boolean,",
				"          InsertedDateUTC as timestamp,",
				"          RowHash_TG as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:false,",
				"     updateable:true,",
				"     upsertable:false,",
				"     keys:['customer_key'],",
				"     skipKeyWrites:true,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'allErrors',",
				"     transactionCommit: 'single',",
				"     reportSuccessOnError: true,",
				"     mapColumn(",
				"          effective_end_date = ValidTo,",
				"          is_current = IsCurrent,",
				"          updated_on,",
				"          updated_by,",
				"          customer_key = SRC_customer_id",
				"     ),",
				"     store: 'sqlserver',",
				"     schemaName: 'dbo') ~> SinkUpdatedRows",
				"select2 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink1",
				"alterRow1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> sink2"
			]
		}
	}
}